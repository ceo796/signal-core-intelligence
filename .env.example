# Signal87 local development / non-Replit deployment example
# Copy to .env locally and fill in secrets. Do not commit real .env files.

NODE_ENV=development
PORT=3000
BASE_PATH=/

# API / database
DATABASE_URL=postgres://user:password@localhost:5432/signal87
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional additional providers (all routed through aiRouter)
XAI_API_KEY=
GROK_MODEL=grok-4.3
# Gemini via Vertex AI service account (Google Cloud credits). Never commit the JSON file.
GEMINI_SERVICE_ACCOUNT_PATH=./.local/gemini-service-account.json
# Vertex region (default us-central1)
# GEMINI_LOCATION=us-central1
# GEMINI_VERTEX_LOCATION=us-central1
# GEMINI_PROJECT_ID=gen-lang-client-0708590149
# Render/production: paste the full JSON as one line (sync: false in dashboard)
# GEMINI_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GEMINI_MODEL=gemini-2.5-flash
# Provider routing — Gemini primary, Grok second, GPT last (change without code edits)
AI_PROVIDER_ROUTING_ENABLED=true
AI_PRIMARY_REASONING_PROVIDER=google
AI_PRIMARY_EXTRACTION_PROVIDER=google
AI_FINAL_FALLBACK_PROVIDER=openai
AI_FALLBACK_PROVIDER_ORDER=xai
# Per-provider LLM attempt timeout in ms (default 12000)
# AI_PROVIDER_TIMEOUT_MS=12000
AI_EVIDENCE_COMPILER_PROVIDER=google
AI_QUALITY_REVIEW_PROVIDER=xai
AI_EMBEDDING_PROVIDER=openai
# AI_FALLBACK_PROVIDER_ORDER=xai,google
# AI_MAX_TOKENS=2048

# Clerk
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
APPROVED_EMAILS=you@example.com
# Admin emails receive full complimentary access (no Stripe required)
ADMIN_EMAILS=ceo@signal87.ai,mbenezra@erezcapital.io

# Stripe subscription billing (Pro recurring monthly price + free trial)
STRIPE_SECRET_KEY=sk_test_...
# Prefer STRIPE_PRICE_ID_PRO for the Pro monthly recurring price (not one-time)
STRIPE_PRICE_ID_PRO=price_...
# Legacy alias — used when STRIPE_PRICE_ID_PRO is unset
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_TRIAL_DAYS=14
# Public web app URL for Checkout/portal fallbacks (preferred over API host)
FRONTEND_URL=https://www.signal87.ai
# APP_URL=https://www.signal87.ai
# STRIPE_SUCCESS_URL=https://www.signal87.ai/documents?billing=success
# STRIPE_CANCEL_URL=https://www.signal87.ai/pricing?billing=cancelled
# STRIPE_PORTAL_RETURN_URL=https://www.signal87.ai/settings
# APP_BASE_URL=https://signal87-api.onrender.com

# Durable file storage outside Replit.
# For Render, mount a persistent disk at /var/data and use /var/data/uploads.
STORAGE_PROVIDER=local
FILE_STORAGE_DIR=./.local/uploads

# Frontend -> API. Leave empty when the frontend is served by the same origin.
VITE_API_BASE_URL=
