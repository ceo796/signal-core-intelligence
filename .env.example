# Signal87 environment variable reference (key names only — no live credentials).
# Copy to .env locally. Production values belong in Render dashboard (sync: false).
# GitHub main is the source of truth; Render deploys from this repo.

# ─── Runtime ───────────────────────────────────────────────────────────────
NODE_ENV=
PORT=
BASE_PATH=
LOG_LEVEL=

# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=

# ─── AI — google → xai → local extractive fallback (OpenAI not required) ───
XAI_API_KEY=
GROK_API_KEY=
GROK_MODEL=
GEMINI_MODEL=
GEMINI_LOCATION=
GEMINI_PROJECT_ID=
GEMINI_SERVICE_ACCOUNT_PATH=
GEMINI_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=
AI_PROVIDER_ROUTING_ENABLED=
AI_PRIMARY_REASONING_PROVIDER=
AI_PRIMARY_EXTRACTION_PROVIDER=
AI_FINAL_FALLBACK_PROVIDER=
AI_FALLBACK_PROVIDER_ORDER=
AI_PROVIDER_TIMEOUT_MS=
AI_EVIDENCE_COMPILER_PROVIDER=
AI_QUALITY_REVIEW_PROVIDER=
AI_MAX_TOKENS=

# ─── Clerk auth ──────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
VITE_CLERK_PUBLISHABLE_KEY=
VITE_CLERK_PROXY_URL=
APPROVED_EMAILS=
ADMIN_EMAILS=

# ─── Stripe billing ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
STRIPE_TRIAL_DAYS=
FRONTEND_URL=
APP_URL=
APP_BASE_URL=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
STRIPE_PORTAL_RETURN_URL=

# ─── Durable file storage (required for uploads; fail-closed if misconfigured) ─
# STORAGE_PROVIDER=local
# Render + persistent disk mounted at /var/data:
# FILE_STORAGE_DIR=/var/data/uploads
# Docker single-container:
# FILE_STORAGE_DIR=/data/uploads
# Local dev example:
# FILE_STORAGE_DIR=./.local/uploads
STORAGE_PROVIDER=
FILE_STORAGE_DIR=

# ─── Frontend build / API routing ──────────────────────────────────────────
# VITE_API_BASE_URL — optional escape hatch only (split-origin or mobile clients).
# Leave blank in same-origin production; the SPA calls relative /api/* on the same host.
# Required only when frontend and API are on different domains.
VITE_API_BASE_URL=
# CORS_ALLOWED_ORIGINS — comma-separated frontend origins; set only for external API mode.
# Leave unset for same-origin Node deployment (production-server.mjs).
CORS_ALLOWED_ORIGINS=
STATIC_DIR=

# ─── Local test / smoke only (never set in production) ─────────────────────
CLERK_BYPASS_AUTH=
DEV_USER_ID=
SMOKE_USER_EMAIL=
SMOKE_BASE_URL=
SMOKE_WEB_BASE_URL=
SMOKE_API_BASE_URL=
API_BASE_URL=
UI_BASE=

# ─── Platform-injected (do not set manually) ─────────────────────────────────
RENDER=